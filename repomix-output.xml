        EntrypointSettings
    )

    config = Config(
        app=app,
        host="0.0.0.0",
        port=entrypoint_settings.api_port,
        reload=False,
    )
    server = Server(config)
    await server.serve()


def run() -> None:
    asyncio.run(run_app())
